# Copy to .env and fill in before running `docker compose up`.
#   cp .env.example .env

# --- Required ---
# Persistent JWT signing secret. If this changes, everyone is logged out.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# First-run admin account (created only if no admin exists yet).
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me-now

# --- Optional ---
# Comma-separated allowed browser origins (default: *). Set this in production.
# CORS_ORIGINS=https://threatmodel.corp.internal

# Enable Claude LLM enhancement (leave blank to run rules-only, fully offline).
# ANTHROPIC_API_KEY=sk-ant-...

# Override the Claude model used for enhancement.
# ANTHROPIC_MODEL=claude-opus-4-8
